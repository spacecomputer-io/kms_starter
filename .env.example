# Server-only — never expose these as NEXT_PUBLIC_*. They authenticate the
# Next.js API routes to the Orbitport gateway via OAuth client credentials.
OP_BASE_URL=https://op.spacecomputer.io
OP_AUTH_DOMAIN=auth.spacecomputer.io
OP_AUTH_AUDIENCE=https://op.spacecomputer.io/api
OP_CLIENT_ID=
OP_CLIENT_SECRET=
